		{
			"name": "04 — Issues: Create",
			"item": [
				{
					"name": "Create Issue — Student (201)",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/v1/issues",
						"header": [{"key": "Authorization", "value": "Bearer {{studentToken}}"},{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\"title\":\"Broken water pipe in Block A\",\"description\":\"Water is leaking from the pipe near room 205 in Block A. The floor is completely wet and slippery.\",\"category\":\"plumbing\",\"location\":\"Block A, Room 205\",\"priority\":\"high\"}"}
					},
					"event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
						"pm.test('Status 201', () => pm.response.to.have.status(201));",
						"const body = pm.response.json();",
						"pm.test('success', () => pm.expect(body.success).to.be.true);",
						"pm.test('has ticketId', () => pm.expect(body.data.issue.ticketId).to.match(/^CMP-/));",
						"pm.test('status is reported', () => pm.expect(body.data.issue.status).to.eql('reported'));",
						"pm.test('priority is high', () => pm.expect(body.data.issue.priority).to.eql('high'));",
						"pm.test('dept resolved', () => pm.expect(body.data.issue.department).to.eql('maintenance'));",
						"pm.test('has escalationDeadline', () => pm.expect(body.data.issue.escalationDeadline).to.be.a('string'));",
						"pm.collectionVariables.set('ticketId', body.data.issue.ticketId);"
					]}}]
				},
				{
					"name": "Create Issue 2 — Admin with assignee (201)",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/v1/issues",
						"header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"},{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\"title\":\"WiFi not working in Library\",\"description\":\"The WiFi access point in the main library reading hall is completely down since morning.\",\"category\":\"wifi\",\"location\":\"Main Library, 2nd Floor\",\"priority\":\"critical\",\"assignedTo\":\"{{staffUserId}}\"}"}
					},
					"event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
						"pm.test('Status 201', () => pm.response.to.have.status(201));",
						"const body = pm.response.json();",
						"pm.test('status is assigned', () => pm.expect(body.data.issue.status).to.eql('assigned'));",
						"pm.test('dept is it', () => pm.expect(body.data.issue.department).to.eql('it'));",
						"pm.collectionVariables.set('ticketId2', body.data.issue.ticketId);"
					]}}]
				},
			{
				"name": "Create Issue 3 — With image attachment (201)",
				"request": {
					"method": "POST",
					"url": "{{baseUrl}}/api/v1/issues",
					"header": [{"key": "Authorization", "value": "Bearer {{studentToken}}"}],
					"body": {
						"mode": "formdata",
						"formdata": [
							{"key": "title", "value": "Broken window in Lab 3", "type": "text"},
							{"key": "description", "value": "The window near the second row of computers is cracked and letting cold air in.", "type": "text"},
							{"key": "category", "value": "furniture", "type": "text"},
							{"key": "location", "value": "CS Lab 3, Block C", "type": "text"},
							{"key": "priority", "value": "medium", "type": "text"},
							{"key": "image", "type": "file", "src": "", "description": "Select a JPG/PNG image (max 5MB) before sending"}
						]
					}
				},
				"event": [{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"// NOTE: This test requires you to select an actual image file in the 'image' field before sending.",
							"// If no file is selected, the issue will still be created successfully (201) but without attachments.",
							"const status = pm.response.code;",
							"pm.test('Status 201', () => pm.response.to.have.status(201));",
							"const body = pm.response.json();",
							"pm.test('success', () => pm.expect(body.success).to.be.true);",
							"pm.test('has ticketId', () => pm.expect(body.data.issue.ticketId).to.match(/^CMP-/));",
							"pm.test('dept is maintenance', () => pm.expect(body.data.issue.department).to.eql('maintenance'));",
							"pm.test('attachments is array', () => pm.expect(body.data.issue.attachments).to.be.an('array'));",
							"if (body.data.issue.attachments.length > 0) {",
							"  pm.test('attachment has url', () => pm.expect(body.data.issue.attachments[0].url).to.be.a('string'));",
							"  pm.test('attachment has publicId', () => pm.expect(body.data.issue.attachments[0].publicId).to.be.a('string'));",
							"  pm.test('attachment has originalName', () => pm.expect(body.data.issue.attachments[0].originalName).to.be.a('string'));",
							"  pm.test('attachment has format', () => pm.expect(body.data.issue.attachments[0].format).to.be.a('string'));",
							"  pm.test('attachment has bytes', () => pm.expect(body.data.issue.attachments[0].bytes).to.be.a('number'));",
							"  pm.test('url points to cloudinary', () => pm.expect(body.data.issue.attachments[0].url).to.include('cloudinary'));",
							"}"
						]
					}
				}]
			},
