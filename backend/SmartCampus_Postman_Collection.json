{
	"info": {
		"_postman_id": "sc-api-2026",
		"name": "Smart Campus API — Complete Test Suite",
		"description": "Comprehensive testing collection for the Smart Campus backend API.\n\n## Setup\n1. Set `baseUrl` variable to `http://localhost:5000`\n2. Run requests in order: Register → Login → then test other endpoints\n3. Tokens are auto-captured from login/register responses\n\n## Test Coverage\n- 13 API endpoints\n- Auth flow (register, login, profile)\n- Dashboard (summary, staff, analytics)\n- Issues (CRUD, assign, status, escalation)\n- Validation & error handling\n- Role-based access control",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{"key": "baseUrl", "value": "http://localhost:5000", "type": "string"},
		{"key": "studentToken", "value": "", "type": "string"},
		{"key": "staffToken", "value": "", "type": "string"},
		{"key": "adminToken", "value": "", "type": "string"},
		{"key": "ticketId", "value": "", "type": "string"},
		{"key": "staffUserId", "value": "", "type": "string"},
		{"key": "adminUserId", "value": "", "type": "string"},
		{"key": "studentUserId", "value": "", "type": "string"},
		{"key": "ticketId2", "value": "", "type": "string"}
	],
	"item": [
		{
			"name": "00 — Health & Base",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/health"
					},
					"event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('success is true', () => pm.expect(pm.response.json().success).to.be.true);",
						"pm.test('has timestamp', () => pm.expect(pm.response.json().timestamp).to.be.a('string'));"
					]}}]
				},
				{
					"name": "API Root",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/api/v1"
					},
					"event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
						"pm.test('Status 200', () => pm.response.to.have.status(200));",
						"pm.test('API running message', () => pm.expect(pm.response.json().message).to.include('running'));"
					]}}]
				},
				{
					"name": "404 — Unknown Route",
					"request": {
						"method": "GET",
						"url": "{{baseUrl}}/api/v1/nonexistent"
					},
					"event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
						"pm.test('Status 404', () => pm.response.to.have.status(404));",
						"pm.test('success is false', () => pm.expect(pm.response.json().success).to.be.false);"
					]}}]
				}
			]
		},
		{
			"name": "01 — Auth: Register",
			"item": [
				{
					"name": "Register Student (valid)",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/v1/auth/register",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\"name\":\"Test Student\",\"email\":\"student_{{$timestamp}}@test.com\",\"password\":\"password123\",\"role\":\"student\"}"}
					},
					"event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
						"pm.test('Status 201', () => pm.response.to.have.status(201));",
						"const body = pm.response.json();",
						"pm.test('success true', () => pm.expect(body.success).to.be.true);",
						"pm.test('has token', () => pm.expect(body.data.token).to.be.a('string'));",
						"pm.test('has user obj', () => pm.expect(body.data.user).to.have.property('id'));",
						"pm.test('role is student', () => pm.expect(body.data.user.role).to.eql('student'));",
						"pm.test('no password leaked', () => pm.expect(body.data.user.password).to.be.undefined);",
						"pm.collectionVariables.set('studentToken', body.data.token);",
						"pm.collectionVariables.set('studentUserId', body.data.user.id);"
					]}}]
				},
				{
					"name": "Register Staff (valid)",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/v1/auth/register",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\"name\":\"Test Staff\",\"email\":\"staff_{{$timestamp}}@test.com\",\"password\":\"password123\",\"role\":\"staff\",\"department\":\"it\"}"}
					},
					"event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
						"pm.test('Status 201', () => pm.response.to.have.status(201));",
						"const body = pm.response.json();",
						"pm.test('role is staff', () => pm.expect(body.data.user.role).to.eql('staff'));",
						"pm.test('dept is it', () => pm.expect(body.data.user.department).to.eql('it'));",
						"pm.collectionVariables.set('staffToken', body.data.token);",
						"pm.collectionVariables.set('staffUserId', body.data.user.id);"
					]}}]
				},
				{
					"name": "Register Admin (valid)",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/v1/auth/register",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\"name\":\"Test Admin\",\"email\":\"admin_{{$timestamp}}@test.com\",\"password\":\"password123\",\"role\":\"admin\",\"department\":\"administration\"}"}
					},
					"event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
						"pm.test('Status 201', () => pm.response.to.have.status(201));",
						"const body = pm.response.json();",
						"pm.test('role is admin', () => pm.expect(body.data.user.role).to.eql('admin'));",
						"pm.collectionVariables.set('adminToken', body.data.token);",
						"pm.collectionVariables.set('adminUserId', body.data.user.id);"
					]}}]
				},
				{
