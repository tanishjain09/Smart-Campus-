							"const body = pm.response.json();",
							"pm.test('success', () => pm.expect(body.success).to.be.true);",
							"pm.test('dept is electrical', () => pm.expect(body.data.issue.department).to.eql('electrical'));",
							"pm.test('no attachments', () => pm.expect(body.data.issue.attachments).to.have.lengthOf(0));"
						]
					}
				}]
			},
				{
					"name": "Create Issue — No auth (401)",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/v1/issues",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\"title\":\"Test Issue\",\"description\":\"This should fail auth check completely\",\"category\":\"wifi\",\"location\":\"Test\"}"}
					},
					"event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
						"pm.test('Status 401', () => pm.response.to.have.status(401));"
					]}}]
				},
				{
					"name": "Create Issue — Short title (400)",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/v1/issues",
						"header": [{"key": "Authorization", "value": "Bearer {{studentToken}}"},{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\"title\":\"Hi\",\"description\":\"This is a valid description for testing\",\"category\":\"wifi\",\"location\":\"Block B\"}"}
