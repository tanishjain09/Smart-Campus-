					]}}]
				},
				{
					"name": "Register — Staff missing dept (400)",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/v1/auth/register",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\"name\":\"Staff NoDept\",\"email\":\"nodept@test.com\",\"password\":\"password123\",\"role\":\"staff\"}"}
					},
					"event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
						"pm.test('Status 400', () => pm.response.to.have.status(400));",
						"pm.test('dept error', () => pm.expect(pm.response.json().message).to.include('Department'));"
					]}}]
				},
				{
					"name": "Register — Duplicate email (409)",
					"request": {
						"method": "POST",
						"url": "{{baseUrl}}/api/v1/auth/register",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\"name\":\"Dup User\",\"email\":\"dup_fixed@test.com\",\"password\":\"password123\"}"}
					},
					"event": [
						{"listen": "prerequest", "script": {"type": "text/javascript", "exec": [
							"// First call to register, second will be the actual test",
							"pm.sendRequest({url: pm.collectionVariables.get('baseUrl') + '/api/v1/auth/register', method: 'POST', header: {'Content-Type': 'application/json'}, body: {mode: 'raw', raw: JSON.stringify({name:'Dup User',email:'dup_fixed@test.com',password:'password123'})}});"
						]}},
						{"listen": "test", "script": {"type": "text/javascript", "exec": [
							"pm.test('Status 409', () => pm.response.to.have.status(409));"
						]}}
					]
				}
			]
		},
